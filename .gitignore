# ── 敏感信息 ──────────────────────────────────
cookies.yaml                    # 抖音登录 Cookie（泄露=账号被盗）
.env                            # 环境变量
*.key                           # 密钥文件
*.pem                           # 证书

# ── 运行时数据 ────────────────────────────────
data/                           # 任务数据库 + 下载文件
logs/                           # 运行时日志

# ── 构建产物 ──────────────────────────────────
dist/                           # PyInstaller 打包输出
build/                          # PyInstaller 构建中间文件
*.spec                          # .spec 已跟踪，排除构建生成的同名文件
*.pkg                           # PyInstaller 中间包
*.toc                           # PyInstaller 中间文件

# ── 发布产物（Releases 走 GitHub Releases）───
releases/                       # 发行的 exe 包（应通过 Releases 发布）

# ── 本地备份 ──────────────────────────────────
备份_*/

# ── Python 缓存 ──────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/

# ── IDE / 编辑器 ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 日志文件 ──────────────────────────────────
*.log
ptu_boot.log
ptu_error.log

# ── 临时调试文件 ──────────────────────────────
_exe_*.log
_exe_*.txt
login_page*.png
