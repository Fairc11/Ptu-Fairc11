# ── 敏感信息 ──────────────────────────────────
# 抖音登录 Cookie（泄露=账号被盗）
cookies.yaml
# 环境变量
.env
# 密钥文件
*.key
# 证书
*.pem

# ── 运行时数据 ────────────────────────────────
# 任务数据库 + 下载文件
data/
# 运行时日志
logs/
# 运行时日志（用户可见）
日志/
# Windows Sandbox 回传日志
sandbox-out/

# ── 构建产物 ──────────────────────────────────
# PyInstaller 打包输出
dist/
# PyInstaller 构建中间文件
build/
# Inno Setup 安装包输出（作为 GitHub Release 资产上传，不进 git）
installer/
# .spec 已跟踪，排除构建生成的同名文件
*.spec
# PyInstaller 中间包
*.pkg
# PyInstaller 中间文件
*.toc

# ── 发布产物（Releases 走 GitHub Releases）───
# 发行的 exe 包（应通过 Releases 发布）
releases/

# ── 本地备份 ──────────────────────────────────
备份_*/

# ── Python 缓存 ──────────────────────────────
__pycache__/
.venv/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/

# ── IDE / 编辑器 ──────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── 日志文件 ──────────────────────────────────
*.log
ptu_boot.log
ptu_error.log

# ── 临时调试文件 ──────────────────────────────
_exe_*.log
_exe_*.txt
login_page*.png
